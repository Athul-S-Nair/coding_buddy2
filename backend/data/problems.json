  {
    "id": "11",
    "title": "Rotate Array",
    "difficulty": "Medium",
    "description": "Given an integer array nums, rotate the array to the right by k steps, where k is non-negative.\n\nInput Format:\nFirst line: integer n\nSecond line: n space-separated integers\nThird line: integer k",
    "examples": [
      {
        "input": "7\n1 2 3 4 5 6 7\n3",
        "output": "5 6 7 1 2 3 4",
        "explanation": "Rotate 3 steps to the right."
      }
    ],
    "constraints": [
      "1 <= nums.length <= 10^5",
      "0 <= k <= 10^5"
    ],
    "testCases": [
      {
        "input": "7\n1 2 3 4 5 6 7\n3",
        "expectedOutput": "5 6 7 1 2 3 4"
      },
      {
        "input": "4\n-1 -100 3 99\n2",
        "expectedOutput": "3 99 -1 -100"
      },
      {
        "input": "1\n1\n0",
        "expectedOutput": "1"
      },
      {
        "input": "2\n1 2\n3",
        "expectedOutput": "2 1"
      }
    ]
  },
