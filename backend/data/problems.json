        "explanation": "Merge all lists into one."
      }
    ],
    "constraints": [
      "0 <= k <= 10^4"
    ],
    "testCases": [
      {
        "input": "3\n3 1 4 5\n3 1 3 4\n2 2 6",
        "expectedOutput": "1 1 2 3 4 4 5 6"
      },
      {
        "input": "0",
        "expectedOutput": ""
      },
      {
        "input": "1\n0",
        "expectedOutput": ""
      },
      {
        "input": "2\n1 1\n1 2",
        "expectedOutput": "1 2"
      }
    ]
