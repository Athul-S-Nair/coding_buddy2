  {
    "id": "3",
    "title": "Sum of Two Numbers",
    "difficulty": "Easy",
    "description": "Given two integers a and b, return their sum.\n\nInput Format:\nFirst line: integer a\nSecond line: integer b",
    "examples": [
      {
        "input": "2\n3",
        "output": "5",
        "explanation": "2 + 3 = 5"
      }
    ],
    "constraints": [
      "-1000 <= a, b <= 1000"
    ],
    "testCases": [
      {
        "input": "2\n3",
        "expectedOutput": "5"
      },
      {
        "input": "10\n20",
        "expectedOutput": "30"
      },
      {
        "input": "-5\n5",
        "expectedOutput": "0"
      },
      {
        "input": "-100\n-200",
        "expectedOutput": "-300"
      },
      {
        "input": "0\n0",
        "expectedOutput": "0"
      },
      {
        "input": "1000\n1000",
        "expectedOutput": "2000"
      },
      {
        "input": "-1000\n-1000",
        "expectedOutput": "-2000"
      },
      {
        "input": "1000\n-1000",
        "expectedOutput": "0"
      },
      {
        "input": "999999\n1",
        "expectedOutput": "1000000"
      },
      {
        "input": "-999999\n-1",
        "expectedOutput": "-1000000"
      }
    ]
  },
  {
    "id": "4",
    "title": "Two Sum",
    "difficulty": "Easy",
    "description": "Given an array of integers nums and an integer target, return indices of the two numbers such that they add up to target.\n\nInput Format:\nFirst line: integer n (size of array)\nSecond line: n space-separated integers\nThird line: target integer",
    "examples": [
      {
        "input": "4\n2 7 11 15\n9",
        "output": "0 1",
        "explanation": "Because nums[0] + nums[1] == 9, we return [0, 1]."
      }
    ],
    "constraints": [
      "2 <= nums.length <= 10^4",
      "-10^9 <= nums[i] <= 10^9",
      "-10^9 <= target <= 10^9"
    ],
    "testCases": [
      {
        "input": "4\n2 7 11 15\n9",
        "expectedOutput": "0 1"
      },
      {
        "input": "3\n3 2 4\n6",
        "expectedOutput": "1 2"
      },
      {
        "input": "2\n3 3\n6",
        "expectedOutput": "0 1"
      },
      {
        "input": "5\n-1 -2 -3 -4 -5\n-8",
        "expectedOutput": "2 4"
      },
      {
        "input": "2\n1 2\n3",
        "expectedOutput": "0 1"
      },
      {
        "input": "4\n1 5 8 10\n18",
        "expectedOutput": "2 3"
      },
      {
        "input": "5\n10 -5 3 7 2\n12",
        "expectedOutput": "0 4"
      },
      {
        "input": "6\n100 200 300 400 500 600\n1100",
        "expectedOutput": "4 5"
      },
      {
        "input": "4\n-100 -50 0 50\n-150",
        "expectedOutput": "0 1"
      },
      {
        "input": "5\n2 2 3 4 5\n4",
        "expectedOutput": "0 1"
      }
    ]
  },
