    "id": "19",
    "title": "Fibonacci Number",
    "difficulty": "Easy",
    "description": "The Fibonacci numbers, commonly denoted F(n) form a sequence, called the Fibonacci sequence, such that each number is the sum of the two preceding ones, starting from 0 and 1. Given n, calculate F(n).\n\nInput Format:\nFirst line: integer n",
    "examples": [
      {
        "input": "2",
        "output": "1",
        "explanation": "F(2) = F(1) + F(0) = 1 + 0 = 1."
      }
    ],
    "constraints": [
      "0 <= n <= 30"
    ],
    "testCases": [
      {
        "input": "2",
        "expectedOutput": "1"
      },
      {
        "input": "3",
        "expectedOutput": "2"
      },
      {
        "input": "4",
        "expectedOutput": "3"
      },
      {
        "input": "0",
        "expectedOutput": "0"
      }
    ]
  }
