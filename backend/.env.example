# Hugging Face API Key (optional — legacy ai-help endpoint)
HUGGINGFACE_API_KEY=your_api_key_here

# Anthropic Claude API Key (required for AI tutor)
ANTHROPIC_API_KEY=your_key_here

# JWT secret for auth cookies
JWT_SECRET=your_jwt_secret_here

# Server Configuration
PORT=5000
FRONTEND_URL=http://localhost:3000

# Self-hosted Judge0 (Docker). Run: docker-compose up -d from project root.
# Leave JUDGE0_API_KEY blank for local self-hosted instance.
JUDGE0_API_URL=http://localhost:2358
JUDGE0_API_KEY=
